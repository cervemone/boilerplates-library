                "2",
                "3",
                "4",
                "5",
                "6",
                "7",
                "8",
                "9"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "redis",
      "title": "Redis",
      "items": [
        {
          "name": "redis_external",
          "type": "bool",
          "title": "External Redis",
          "required": false,
          "default": false,
          "description": "Use an existing Redis instance by setting REDIS_URL in the Infisical Kubernetes Secret."
        },
        {
          "name": "redis_url",
          "type": "secret",
          "title": "Redis URL",
          "required": true,
          "default": "redis://:CHANGE_ME@redis.example.internal:6379",
          "description": "Full Redis URL for external Redis.",
          "needs": [
            "redis_external=true"
          ],
          "config": {
            "placeholder": "redis://:password@redis.example.internal:6379"
          }
        },
        {
          "name": "redis_password",
          "type": "secret",
          "title": "Redis Password",
          "required": true,
          "description": "Redis password for the bundled Redis chart, written to helm-secrets.yaml.",
          "needs": [
            "redis_external=false"
          ],
          "config": {
            "autogenerated": {
              "length": 32,
              "characters": [
                "a",
                "b",
                "c",
                "d",
                "e",
                "f",
                "g",
                "h",
                "i",
                "j",
                "k",
                "l",
                "m",
                "n",
                "o",
                "p",
                "q",
                "r",
                "s",
                "t",
                "u",
                "v",
                "w",
                "x",
