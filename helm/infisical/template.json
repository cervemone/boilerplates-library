              ]
            }
          }
        },
        {
          "name": "redis_persistence_enabled",
          "type": "bool",
          "title": "Redis Persistence",
          "required": false,
          "default": true,
          "description": "Enable PVC persistence for the bundled Redis chart.",
          "needs": [
            "redis_external=false"
          ]
        },
        {
          "name": "redis_storage_class",
          "type": "str",
          "title": "Redis StorageClass",
          "required": false,
          "default": "ceph-rbd",
          "description": "StorageClass for the bundled Redis PVC.",
          "needs": [
            "redis_external=false",
            "redis_persistence_enabled=true"
          ],
          "config": {
            "placeholder": "ceph-rbd"
          }
        },
        {
          "name": "redis_storage_size",
          "type": "str",
          "title": "Redis Storage Size",
          "required": false,
          "default": "2Gi",
          "description": "PVC size for the bundled Redis chart.",
          "needs": [
            "redis_external=false",
            "redis_persistence_enabled=true"
          ],
          "config": {
            "placeholder": "2Gi"
          }
        }
      ]
    },
    {
      "name": "resources",
      "title": "Resources",
      "items": [
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU Request",
          "required": false,
          "default": "250m",
          "description": "CPU request for Infisical pods.",
          "config": {
            "placeholder": "250m"
          }
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory Request",
          "required": false,
          "default": "512Mi",
          "description": "Memory request for Infisical pods.",
          "config": {
            "placeholder": "512Mi"
          }
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory Limit",
          "required": false,
          "default": "1000Mi",
          "description": "Memory limit for Infisical pods.",
          "config": {
            "placeholder": "1000Mi"
          }
        },
        {
          "name": "redis_cpu_request",
          "type": "str",
          "title": "Redis CPU Request",
          "required": false,
          "default": "50m",
          "description": "CPU request for bundled Redis.",
          "needs": [
            "redis_external=false"
          ],
          "config": {
            "placeholder": "50m"
          }
        },
        {
          "name": "redis_memory_request",
          "type": "str",
          "title": "Redis Memory Request",
          "required": false,
          "default": "128Mi",
          "description": "Memory request for bundled Redis.",
          "needs": [
            "redis_external=false"
          ],
          "config": {
            "placeholder": "128Mi"
          }
        },
        {
          "name": "redis_memory_limit",
          "type": "str",
          "title": "Redis Memory Limit",
          "required": false,
          "default": "256Mi",
          "description": "Memory limit for bundled Redis.",
          "needs": [
            "redis_external=false"
          ],
          "config": {
            "placeholder": "256Mi"
          }
        }
      ]
    },
    {
      "name": "email",
      "title": "Email",
      "toggle": "email_enabled",
      "items": [
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "SMTP Email",
          "required": false,
          "default": false,
          "description": "Add SMTP keys to the Infisical Kubernetes Secret."
        },
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP Host",
          "required": true,
          "default": "smtp.home.arpa",
          "description": "SMTP server hostname.",
          "needs": [
            "email_enabled=true"
          ],
          "config": {
            "placeholder": "smtp.home.arpa"
          }
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP Port",
          "required": true,
          "default": 587,
          "description": "SMTP server port.",
          "needs": [
            "email_enabled=true"
          ],
          "config": {
            "placeholder": "587"
          }
        },
        {
          "name": "email_from_address",
          "type": "str",
          "title": "From Address",
          "required": true,
          "default": "infisical@home.arpa",
          "description": "Sender email address.",
          "needs": [
            "email_enabled=true"
          ],
          "config": {
            "placeholder": "infisical@home.arpa"
          }
        },
        {
          "name": "email_from_name",
          "type": "str",
          "title": "From Name",
          "required": false,
          "default": "Infisical",
          "description": "Sender display name.",
          "needs": [
            "email_enabled=true"
          ],
          "config": {
            "placeholder": "Infisical"
          }
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP Username",
          "required": true,
          "default": "",
          "description": "SMTP username.",
          "needs": [
            "email_enabled=true"
          ]
        },
        {
          "name": "email_password",
          "type": "secret",
          "title": "SMTP Password",
          "required": false,
          "default": "",
          "description": "SMTP password.",
          "needs": [
            "email_enabled=true"
          ]
        },
        {
          "name": "email_secure",
          "type": "bool",
          "title": "SMTP Secure",
          "required": false,
          "default": false,
          "description": "Use implicit TLS for SMTP.",
          "needs": [
            "email_enabled=true"
          ]
        },
        {
          "name": "email_require_tls",
          "type": "bool",
          "title": "Require TLS",
          "required": false,
          "default": true,
          "description": "Require STARTTLS for SMTP.",
          "needs": [
            "email_enabled=true"
          ]
        },
        {
          "name": "email_ignore_tls",
          "type": "bool",
          "title": "Ignore TLS",
          "required": false,
          "default": false,
          "description": "Ignore TLS for SMTP.",
          "needs": [
            "email_enabled=true"
          ]
        }
      ]
    }
  ]
}
